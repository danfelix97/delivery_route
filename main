#include <iostream>
#include <vector>
#include <queue>
#include <climits>
using namespace std; 

int cheapestRoute(int src, int dst, int k, int n, vector<vector<int>>& routes) { //the route which contains the center, destination and how many stops

    vector<vector<pair<int, int>>> graph(n); //a graph for neighbors and prices
    for (auto& r:routes)
        graph[r[0]].push_back({r[1], r[2]}); //how the route goes

    vector <int> minCost(n, INT_MAX); //min cost to reach the center
    minCost[src]=0; //it will cost 0

    queue<tuple<int, int, int>> q;
    q.push({0, src, 0}); //start at the center with 0 cost and 0 stops

    while (!q.empty()) { //keep going 
        auto [cost, node, stops] = q.front(); q.pop(); //the path coming up
        if (stops > k) continue; //if there are too many stops, find another

        for (auto& [neighbor, price]:graph[node]) { //neighbor and price of node
            int new_cost = cost+price; //cost of reaching the neighbor
            if (new_cost<minCost[neighbor]) { 
                minCost[neighbor] = new_cost; //a new min cost
                q.push({new_cost, neighbor, stops+1}); //+1 to the queue
            }
        }
    }

    return minCost[dst]== INT_MAX?-1: minCost[dst]; //destination not reached = -1
}

int main() {
    vector<vector<int>> routes = {{0, 1, 100}, {1, 2, 100}, {0, 2, 500}};
    cout << "Test 1: " << cheapestRoute(0, 2, 1, 3, routes) << endl;
    cout << "Test 2: " << cheapestRoute(0, 2, 0, 3, routes) << endl;
    cout << "Test 3: " << cheapestRoute(0, 3, 1, 4, routes) << endl;
}
